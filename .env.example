# Copy to .env and fill in. NEVER commit .env (it is gitignored).
# On Render, set these as Environment Variables in the dashboard instead.

# Postgres connection string (Neon). Required.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Secret used to sign session cookies. Required in production (the server
# refuses to start in production without it). Use a long random string.
SESSION_SECRET=change-me-to-a-long-random-string

# development | production
NODE_ENV=development

# Port the server listens on (Render sets this automatically).
PORT=5000
